<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
    Parallel execution strategy:
    - parallel="tests" + thread-count="3" tells TestNG to run each <test>
      block below on its own thread.
    - Each <test> block targets a different browser. Because all of them
      point at the same Grid hub URL (configured in config.properties /
      via -DgridUrl), the hub transparently routes each session to whichever
      registered node (Chrome, Firefox, Edge) can satisfy that capability.
    - This is what gives the "distributed across multiple nodes and
      browsers, in parallel" behavior.
-->
<suite name="DistributedGridSuite" parallel="tests" thread-count="3" verbose="1">

    <test name="Chrome-Tests">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.framework.tests.GoogleSearchTest"/>
            <class name="com.framework.tests.NavigationTest"/>
        </classes>
    </test>

    <test name="Firefox-Tests">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="com.framework.tests.GoogleSearchTest"/>
            <class name="com.framework.tests.NavigationTest"/>
        </classes>
    </test>

    <test name="Edge-Tests">
        <parameter name="browser" value="edge"/>
        <classes>
            <class name="com.framework.tests.GoogleSearchTest"/>
            <class name="com.framework.tests.NavigationTest"/>
        </classes>
    </test>

</suite>
